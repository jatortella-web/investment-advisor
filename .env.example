# ─── Financial Data API Keys ──────────────────────────────────────────────────
# Alpha Vantage – real-time & historical market data
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# CoinGecko – cryptocurrency prices (public API, key optional for higher limits)
NEXT_PUBLIC_COINGECKO_API_KEY=your_coingecko_key_here

# Polygon.io – stocks, ETFs, and index data
POLYGON_API_KEY=your_polygon_key_here

# ─── App Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
